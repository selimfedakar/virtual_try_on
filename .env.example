# ── Supabase ────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ── App ─────────────────────────────────────────────────────────────────
# Public base URL of this deployment (used to build the Fashn.ai webhook URL)
NEXT_PUBLIC_APP_URL=https://virtual-try-on-three-sage.vercel.app

# ── Fashn.ai (virtual try-on) ───────────────────────────────────────────
FASHN_API_KEY=your_fashn_api_key_here
# REQUIRED — webhook is fail-closed and rejects all deliveries when unset
FASHN_WEBHOOK_SECRET=long_random_string_here

# ── Anthropic (AI Stylist) ──────────────────────────────────────────────
# /api/stylist returns 503 stylist_unavailable when unset
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── RevenueCat (server-side entitlement sync) ───────────────────────────
# Full Authorization header value, must match the RevenueCat webhook config exactly
REVENUECAT_WEBHOOK_AUTH=Bearer_long_random_string_here

# ── Admin & Ops ─────────────────────────────────────────────────────────
# Comma-separated emails that bypass the daily generation quota (empty = none)
ADMIN_EMAILS=
# Protects /api/cron/cleanup; Vercel sends it automatically to cron invocations
CRON_SECRET=long_random_string_here
